# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# 비공개 문서 (설계 로그 등)
docs/_personal/

# LLM 프롬프트 캐시 (재생성 가능)
cache/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# 크롤링 원문·수집 대장 (사람인 DB권 — 통째로 미커밋). 재현은 README 본문의 공고 URL로.
# 매칭 재실행에 필요한 추출 결과는 extracted/(구조화 파생물)로 커밋한다.
fixtures/
