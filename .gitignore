# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# 비공개 문서 (설계 로그 등)
docs/_personal/

# LLM 프롬프트 캐시 (재생성 가능)
cache/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# 크롤링 원문 (사람인 DB권 — 절대 커밋 금지). 단 수집 대장(README)만 예외로 추적.
fixtures/*
!fixtures/README.md
